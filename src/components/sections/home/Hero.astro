---
// components
import Container from "../../elements/Container.astro"
import Text from "../../elements/Text.astro"
import Heading from "../../elements/Heading.astro"
import ImageContainer from "../../elements/ImageContainer.astro"
import Link from "../../elements/Link.astro"

// assets
import aldjon from "../../../assets/images/aldjon2.jpg";
---

<Container variant={"xl"} class="flex flex-col gap-8 min-h-screen">
    <Container class="flex md:flex-row flex-col gap-8">
        <Container class="md:flex-2 flex flex-col items-start gap-4">
            <Link variant={'button'} href="/contact">Work Details</Link>
            <Heading tagName="h1" tagSize="h1">Aldjon Cayl P. Dela Cruz</Heading>
        </Container>
        <Container class="h-full md:h-[500px] flex-1">
            <ImageContainer src={aldjon} alt="Aldjon Cayl P. Dela Cruz" />
        </Container>
    </Container>
    <Text variant={'xl'} class="text-base-900 lg:max-w-1/3 md:max-w-1/2 w-full">
        <br />
        Aspiring software developer passionate about creating innovative applications and software that solve real-world problems. I enjoy transforming ideas into practical solutions that make a positive impact on people's lives.
    </Text>
</Container>
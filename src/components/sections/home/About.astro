---
// components
import Heading from "../../elements/Heading.astro";
import Text from "../../elements/Text.astro";
import Container from "../../elements/Container.astro";
import Link from "../../elements/Link.astro";
import ImageContainer from "../../elements/ImageContainer.astro";

// assets
import aldjon2 from "../../../assets/images/Your Name.jpg";
---

<Container variant={'xl'}>
    <Heading tagName="h2" tagSize="h2" class="text-center">About</Heading>
    <div class="flex lg:flex-row lg:gap-16 gap-10 flex-col">
        <div class="flex flex-col items-start gap-6 lg:pt-6 text-base-900 lg:flex-1">
            <Text variant={'xl'}>Turning ideas into practical solutions that make a positive impact.</Text>
            <Text variant={'sm'}>With a passion for creating something innovative that helps people</Text>
            <Text variant={'sm'}>When I'm not developing I'm playing video games, drawing, or listening to music.</Text>
            <Link variant={'button'} href="/about">More about me</Link>
        </div>
        <div class="w-full lg:h-[500px] h-auto lg:flex-1">
            <ImageContainer src={aldjon2} alt="Aldjon Cayl P. Dela Cruz" />
        </div>
    </div>
</Container>